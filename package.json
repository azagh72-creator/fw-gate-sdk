  "repository": {
    "type": "git",
    "url": "https://github.com/azagh72-creator/fw-gate-sdk"
  },
  "homepage": "https://fwgate.to",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
